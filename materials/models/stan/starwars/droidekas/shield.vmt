"VertexlitGeneric"
{
	"$basetexture" "models/stan/starwars/droidekas/shield3"
		"$detail" "effects\tiledfire\bluefire\firelayeredslowtiled512a.vtf"	
	"$detailscale" "1"
	"$detailblendfactor" .8
	"$detailblendmode" 6

     $shield 0
	"$translucent" 1
	"$phong"	"1"
	"$phongboost"	"2"
	"$phongexponent"	"60"
	"$phongfresnelranges"	"[.1 .1 .2]"
		// Cloaking
	"$cloakPassEnabled" "1"
	
"proxies"
	{
		"spy_invis"
		{
		}
		"AnimatedTexture"
		{
			"animatedtexturevar" "$detail"
			"animatedtextureframenumvar" "$detailframe"
			"animatedtextureframerate" 40
		
			
		}
	    "alphaVar"
		{
		$alpha $shield
		}
	}
	
}